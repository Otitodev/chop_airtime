# LLM
# LLM_PROVIDER controls which model is tried first: openai | mistral | anthropic
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest

# Database — Neon (or any PostgreSQL)
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# VTpass (primary VTU provider)
VTPASS_API_KEY=your-vtpass-api-key
VTPASS_SECRET_KEY=your-vtpass-secret-key
VTPASS_BASE_URL=https://vtpass.com/api

# VTU.ng (fallback VTU provider)
VTU_NG_JWT_TOKEN=your-vtu-ng-jwt-token
VTU_NG_BASE_URL=https://vtu.ng/wp-json/vtu-ng/v1

# Evolution API (WhatsApp)
EVOLUTION_API_WEBHOOK_SECRET=your-webhook-hmac-secret
EVOLUTION_API_URL=https://your-evolution-instance.com
EVOLUTION_API_INSTANCE=your-instance-name
EVOLUTION_API_KEY=your-evolution-api-key

# SMTP (email alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
ALERT_EMAIL_TO=owner@email.com

# Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Business rules (defaults shown)
LOW_BALANCE_THRESHOLD=500
USER_LIFETIME_CAP=500
MIN_TOPUP=50
MAX_TOPUP=500

# CORS — comma-separated origins (* for development)
CORS_ORIGINS=*
